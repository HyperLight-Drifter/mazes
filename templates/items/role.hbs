<div class="item-sheet-body">

  <div class="item-sheet-row">
    <div class="item-sheet-field">
      <span class="mazes-label">NAME</span>
      <input type="text" name="name" value="{{item.name}}" />
    </div>
  </div>

  <div class="item-sheet-row">
    <div class="item-sheet-field narrow">
      <span class="mazes-label">DIE</span>
      <select name="system.die">
        {{#each dieOptions}}
        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{value}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <div class="item-sheet-row">
    <div class="item-sheet-field narrow">
      <span class="mazes-label">HEARTS</span>
      <input type="text" readonly value="{{item.heartsDerived}}" />
    </div>
    <div class="item-sheet-field narrow">
      <span class="mazes-label">STARS</span>
      <input type="text" readonly value="{{item.starsDerived}}" />
    </div>
  </div>

  <div class="item-sheet-field">
    <span class="mazes-label">DESCRIPTION</span>
    <textarea name="system.description">{{system.description}}</textarea>
  </div>

</div>